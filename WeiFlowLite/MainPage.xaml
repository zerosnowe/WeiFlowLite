                    <Grid x:Name="SettingsPanel"
                          Visibility="Collapsed"
                          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                        <Grid.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromHorizontalOffset="24"/>
                            </TransitionCollection>
                        </Grid.Transitions>
                        <Frame x:Name="SettingsFrame"/>
                    </Grid>

                    <Grid x:Name="MediaPreviewOverlay"
                          Visibility="Collapsed"
                          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                          Canvas.ZIndex="100">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition x:Name="MediaPreviewBottomRow" Height="56"/>
                        </Grid.RowDefinitions>
                        <Grid.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromHorizontalOffset="96"/>
                            </TransitionCollection>
                        </Grid.Transitions>
                        <Grid x:Name="MediaPreviewHeader"
                              Grid.Row="0"
                              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                            <Button Width="48"
                                    Height="48"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    Click="MediaPreviewBackButton_Click">
                                <FontIcon Glyph="&#xE72B;"/>
                            </Button>
                            <TextBlock x:Name="MediaPreviewTitle"
                                       Text="媒体预览"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"/>
                        </Grid>
                        <Border x:Name="MediaPreviewContentHost"
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="Transparent">
                            <Grid>
                                <ScrollViewer x:Name="PreviewImageScrollViewer"
                                              Visibility="Collapsed"
                                              ZoomMode="Enabled"
                                              MinZoomFactor="1"
                                              MaxZoomFactor="4"
                                              HorizontalScrollBarVisibility="Auto"
                                              VerticalScrollBarVisibility="Auto"
                                              PointerWheelChanged="PreviewImageScrollViewer_PointerWheelChanged">
                                    <Image x:Name="PreviewImage"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Stretch="Uniform"/>
                                </ScrollViewer>
                                <Grid x:Name="PreviewVideoHost"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <Border x:Name="MediaPreviewBottomBar"
                                Grid.Row="2"
                                Height="56"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Bottom"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                BorderBrush="#22000000"
                                BorderThickness="0,1,0,0"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Width="96"
                                        Background="Transparent"
                                        Click="MediaPreviewSaveButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE118;"
                                                  FontSize="14"
                                                  Margin="0,0,6,0"/>
                                        <TextBlock Text="保存"/>
                                    </StackPanel>
                                </Button>
                                <Button Width="96"
                                        Background="Transparent"
                                        Click="MediaPreviewShareButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <FontIcon Glyph="&#xE72D;"
                                                  FontSize="14"
                                                  Margin="0,0,6,0"/>
                                        <TextBlock Text="分享"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </SplitView.Content>
        </SplitView>
        <ToggleButton x:Name="HamburgerButton"
                      Width="48"
                      Height="48"
                      VerticalAlignment="Top"
                      HorizontalAlignment="Left"
                      Background="Transparent"
                      Checked="HamburgerButton_Checked"
                      Unchecked="HamburgerButton_Unchecked">
            <FontIcon Glyph="&#xE700;" FontSize="16"/>
        </ToggleButton>
        <Border x:Name="TitleBarDragRegion"
                Height="32"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Background="Transparent"
                Canvas.ZIndex="10"
                Visibility="Collapsed"/>
    </Grid>
</Page>
