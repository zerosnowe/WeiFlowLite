<Page
    x:Class="WeiFlowLite.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WeiFlowLite"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Unloaded="MainPage_Unloaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
            <ResourceDictionary x:Key="Default">
                <SolidColorBrush x:Key="WeiboTextBoxBackgroundBrush" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="WeiboTextBoxForegroundBrush" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="WeiboTextBoxBorderBrush" Color="#33000000"/>
                <SolidColorBrush x:Key="WeiboTextBoxPlaceholderBrush" Color="#99000000"/>
                <SolidColorBrush x:Key="TextControlBackground" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlForeground" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#99000000"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#99000000"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#99000000"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Light">
                <SolidColorBrush x:Key="WeiboTextBoxBackgroundBrush" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="WeiboTextBoxForegroundBrush" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="WeiboTextBoxBorderBrush" Color="#33000000"/>
                <SolidColorBrush x:Key="WeiboTextBoxPlaceholderBrush" Color="#99000000"/>
                <SolidColorBrush x:Key="TextControlBackground" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="TextControlForeground" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#33000000"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#99000000"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#99000000"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#99000000"/>
            </ResourceDictionary>
            <ResourceDictionary x:Key="Dark">
                <SolidColorBrush x:Key="WeiboTextBoxBackgroundBrush" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="WeiboTextBoxForegroundBrush" Color="#FFF2F2F2"/>
                <SolidColorBrush x:Key="WeiboTextBoxBorderBrush" Color="#40FFFFFF"/>
                <SolidColorBrush x:Key="WeiboTextBoxPlaceholderBrush" Color="#99FFFFFF"/>
                <SolidColorBrush x:Key="TextControlBackground" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#FF1F1F1F"/>
                <SolidColorBrush x:Key="TextControlForeground" Color="#FFF2F2F2"/>
                <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#FFF2F2F2"/>
                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#FFF2F2F2"/>
                <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#FFF2F2F2"/>
                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#40FFFFFF"/>
                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#40FFFFFF"/>
                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#40FFFFFF"/>
                <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#40FFFFFF"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#99FFFFFF"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#99FFFFFF"/>
                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#99FFFFFF"/>
            </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <FontFamily x:Key="SymbolThemeFontFamily">Segoe Fluent Icons,Segoe MDL2 Assets,Segoe UI Symbol</FontFamily>
            <local:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter"/>
            <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <SolidColorBrush x:Key="PivotHeaderItemSelectedForeground" Color="#FF8200"/>
            <SolidColorBrush x:Key="PivotHeaderItemSelectedPointerOverForeground" Color="#FF8200"/>
            <SolidColorBrush x:Key="PivotHeaderItemSelectedPressedForeground" Color="#FF8200"/>
            <Style x:Key="WeiboListViewStyle" TargetType="ListView">
                <Setter Property="SelectionMode" Value="None"/>
                <Setter Property="IsItemClickEnabled" Value="True"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            </Style>
            <Style x:Key="NavListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
            </Style>
            <Style x:Key="NavIconStyle" TargetType="FontIcon">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>
            <Style TargetType="TextBox">
                <Setter Property="Foreground" Value="{ThemeResource WeiboTextBoxForegroundBrush}"/>
                <Setter Property="Background" Value="{ThemeResource WeiboTextBoxBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource WeiboTextBoxBorderBrush}"/>
            </Style>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <SplitView x:Name="RootSplitView"
                   DisplayMode="Overlay"
                   CompactPaneLength="48"
                   OpenPaneLength="320"
                   IsPaneOpen="False">
            <SplitView.Pane>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListView x:Name="NavListView"
                              Grid.Row="1"
                              SelectionMode="Single"
                              SelectionChanged="NavListView_SelectionChanged"
                              Background="Transparent"
                              ItemContainerStyle="{StaticResource NavListViewItemStyle}">
                        <ListViewItem x:Name="NavHomeItem" Tag="home">
                            <Grid Height="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE80F;" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Grid.Column="1" Text="主页" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </ListViewItem>
                        <ListViewItem x:Name="NavSearchItem" Tag="search">
                            <Grid Height="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE721;" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Grid.Column="1" Text="搜索" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </ListViewItem>
                        <ListViewItem x:Name="NavMessageItem" Tag="messages">
                            <Grid Height="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE715;" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Grid.Column="1" Text="消息" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </ListViewItem>
                    </ListView>
                    <ListView x:Name="NavFooterListView"
                              Grid.Row="2"
                              SelectionMode="Single"
                              SelectionChanged="NavFooterListView_SelectionChanged"
                              Background="Transparent"
                              ItemContainerStyle="{StaticResource NavListViewItemStyle}">
                        <ListViewItem x:Name="NavLoginItem" Tag="login">
                            <Grid Height="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE77B;" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Grid.Column="1" Text="登录" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </ListViewItem>
                        <ListViewItem x:Name="NavSettingsItem" Tag="settings">
                            <Grid Height="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="&#xE713;" Style="{StaticResource NavIconStyle}"/>
                                <TextBlock Grid.Column="1" Text="设置" Margin="0,0,12,0" VerticalAlignment="Center" FontSize="14"/>
                            </Grid>
                        </ListViewItem>
                    </ListView>
                </Grid>
            </SplitView.Pane>
            <SplitView.Content>
                <Grid x:Name="MainContentHost" Margin="48,0,0,0" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                    <Grid.ChildrenTransitions>
                        <TransitionCollection>
                            <ReorderThemeTransition/>
                        </TransitionCollection>
                    </Grid.ChildrenTransitions>

                    <Grid x:Name="HomePanel"
                          Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                        <Grid.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromHorizontalOffset="-24"/>
                            </TransitionCollection>
                        </Grid.Transitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="HomeListColumn" Width="430"/>
                            <ColumnDefinition x:Name="HomeDetailColumn" Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border x:Name="CategoryHeaderBackground"
                                Grid.Row="0"
                                Grid.Column="0"
                                Margin="0,0,0,4"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                            <Pivot x:Name="CategoryPivot"
                                   Height="48"
                                   Padding="4,0"
                                   HorizontalAlignment="Stretch"
                                   MaxWidth="{Binding ActualWidth, ElementName=HomePanel}"
                                   SelectionChanged="CategoryPivot_SelectionChanged"/>
                        </Border>

                        <ListView x:Name="WeiboListView"
                                  Grid.Row="1"
                                  Grid.Column="0"
                                  Style="{StaticResource WeiboListViewStyle}"
                                  ItemClick="WeiboListView_ItemClick"
                                  Loaded="WeiboListView_Loaded">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Grid.Column="0"
                                                         Width="40"
                                                         Height="40"
                                                         Margin="0,0,10,0">
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding ProfileImage}"
                                                                    Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>

                                                <Grid Grid.Column="1"
                                                      VerticalAlignment="Center">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0"
                                                               Text="{Binding User.ScreenName}"
                                                               FontSize="15"
                                                               FontWeight="SemiBold"
                                                               Foreground="#EB7340"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding MetaText}"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                </Grid>
                                            </Grid>

                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Text}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap"
                                                       LineHeight="22"
                                                       MaxLines="8"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,0,0,8"/>

                                            <GridView Grid.Row="2"
                                                      ItemsSource="{Binding Pics}"
                                                      Margin="0,0,0,8"
                                                      SelectionMode="None"
                                                      IsItemClickEnabled="True"
                                                      ItemClick="MediaGridView_ItemClick"
                                                      Visibility="{Binding Pics, Converter={StaticResource CollectionToVisibilityConverter}}"
                                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                      ScrollViewer.VerticalScrollMode="Disabled">
                                                <GridView.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <ItemsWrapGrid Orientation="Horizontal"
                                                                       MaximumRowsOrColumns="3"/>
                                                    </ItemsPanelTemplate>
                                                </GridView.ItemsPanel>
                                                <GridView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Width="110"
                                                              Height="110"
                                                              Margin="0,0,4,4">
                                                            <Image Source="{Binding Source}"
                                                                   Stretch="Uniform"/>
                                                            <Border Background="#66000000"
                                                                    CornerRadius="18"
                                                                    Width="36"
                                                                    Height="36"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Visibility="{Binding VideoGlyphVisibility}">
                                                                <FontIcon Glyph="&#xE768;"
                                                                            Foreground="White"
                                                                            FontSize="16"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </DataTemplate>
                                                </GridView.ItemTemplate>
                                            </GridView>

                                            <TextBlock Grid.Row="3"
                                                       FontSize="12"
                                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0">
                                                <Run Text="转发 "/>
                                                <Run Text="{Binding RepostsCount}"/>
                                                <Run Text="    评论 "/>
                                                <Run Text="{Binding CommentsCount}"/>
                                                <Run Text="    赞 "/>
                                                <Run Text="{Binding AttitudesCount}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.Footer>
                                <StackPanel x:Name="LoadingMoreIndicator"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Margin="0,16"
                                            Visibility="Collapsed">
                                    <ProgressBar x:Name="LoadingMoreBar"
                                                  Width="20"
                                                  Height="20"
                                                  IsIndeterminate="True"/>
                                    <TextBlock Text="正在加载更多推荐"
                                               Margin="8,2,0,0"
                                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </ListView.Footer>
                        </ListView>

                        <StackPanel Grid.RowSpan="2"
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <ProgressBar x:Name="LoadingIndicator"
                                         Width="72"
                                         Height="6"
                                         IsIndeterminate="True"
                                         Visibility="Collapsed"/>
                            <TextBlock Text="正在加载微博"
                                       Margin="0,10,0,0"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding Visibility, ElementName=LoadingIndicator}"
                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                        </StackPanel>

                        <Border x:Name="DetailPanel"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                            <Border.Transitions>
                                <TransitionCollection>
                                    <EntranceThemeTransition FromHorizontalOffset="96"/>
                                </TransitionCollection>
                            </Border.Transitions>
                            <Grid>
                                <TextBlock x:Name="DetailPlaceholder"
                                           Text="选择一条微博查看正文"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <ProgressBar x:Name="DetailLoadingIndicator"
                                              Width="56"
                                              Height="6"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              IsIndeterminate="True"
                                              Visibility="Collapsed"/>
                                <ScrollViewer x:Name="DetailScrollViewer"
                                              Visibility="Collapsed"
                                              HorizontalScrollBarVisibility="Disabled"
                                              HorizontalScrollMode="Disabled"
                                              Padding="24,16,24,56">
                                    <StackPanel x:Name="DetailContent">
                                        <Button x:Name="DetailBackButton"
                                                Width="48"
                                                Height="48"
                                                Padding="0"
                                                Margin="-12,0,0,0"
                                                Background="Transparent"
                                                Visibility="Collapsed"
                                                Click="DetailBackButton_Click">
                                            <FontIcon Glyph="&#xE72B;"/>
                                        </Button>
                                        <Grid Margin="0,0,0,4"
                                              Tapped="DetailUserHeader_Tapped">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0"
                                                     Width="48"
                                                     Height="48"
                                                     Margin="0,0,12,0">
                                                <Ellipse.Fill>
                                                    <ImageBrush ImageSource="{Binding ProfileImage}"
                                                                Stretch="UniformToFill"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding User.ScreenName}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="#EB7340"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding MetaText}"
                                                           FontSize="12"
                                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="2"
                                                    MinWidth="84"
                                                    Height="34"
                                                    Padding="10,0"
                                                    Background="Transparent"
                                                    Click="DetailFollowButton_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <FontIcon Glyph="{Binding FollowIconGlyph}"
                                                              FontSize="13"
                                                              Margin="0,0,5,0"/>
                                                    <TextBlock Text="{Binding FollowText}"
                                                               FontSize="13"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <TextBox Text="{Binding Text, Mode=OneWay}"
                                                 FontSize="16"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 IsReadOnly="True"
                                                 BorderThickness="0"
                                                 Padding="0"
                                                 Background="Transparent"/>

                                        <ListView ItemsSource="{Binding Pics}"
                                                  SelectionMode="None"
                                                  IsItemClickEnabled="True"
                                                  ItemClick="MediaGridView_ItemClick"
                                                  Visibility="{Binding Pics, Converter={StaticResource CollectionToVisibilityConverter}}"
                                                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollMode="Disabled">
                                            <ListView.ItemContainerStyle>
                                                <Style TargetType="ListViewItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                                </Style>
                                            </ListView.ItemContainerStyle>
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid HorizontalAlignment="Stretch">
                                                        <Image Source="{Binding Source}"
                                                               Stretch="Uniform"
                                                               HorizontalAlignment="Stretch"/>
                                                        <Border Background="#66000000"
                                                                CornerRadius="22"
                                                                Width="44"
                                                                Height="44"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                Visibility="{Binding VideoGlyphVisibility}">
                                                            <FontIcon Glyph="&#xE768;"
                                                                        Foreground="White"
                                                                        FontSize="16"
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>

                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <FontIcon x:Name="DetailRepostFluentIcon" Glyph="&#xE8CB;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,5,0"/>
                                            <FontIcon x:Name="DetailRepostMdl2Icon" Glyph="&#xE72D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,5,0" Visibility="Collapsed"/>
                                            <TextBlock Text="{Binding RepostsCount}" FontSize="13" VerticalAlignment="Center" Margin="0,0,18,0"/>
                                            <FontIcon x:Name="DetailCommentStatFluentIcon" Glyph="&#xE8BD;" FontFamily="Segoe Fluent Icons" FontSize="14" Margin="0,0,5,0"/>
                                            <FontIcon x:Name="DetailCommentStatMdl2Icon" Glyph="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,5,0" Visibility="Collapsed"/>
                                            <TextBlock Text="{Binding CommentsCount}" FontSize="13" VerticalAlignment="Center" Margin="0,0,18,0"/>
                                            <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEB51;" FontSize="14" Margin="0,0,5,0"/>
                                            <TextBlock Text="{Binding AttitudesCount}" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="评论"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Margin="0,16,0,0"/>
                                        <ListView x:Name="DetailCommentsList"
                                                  SelectionMode="None"
                                                  IsItemClickEnabled="False">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Grid.Column="0"
                                                                 Width="36"
                                                                 Height="36"
                                                                 Margin="0,0,10,0"
                                                                 Tapped="CommentAvatar_Tapped">
                                                            <Ellipse.Fill>
                                                                <ImageBrush ImageSource="{Binding ProfileImage}"
                                                                            Stretch="UniformToFill"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding UserName}"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#EB7340"
                                                                       TextWrapping="Wrap"/>
                                                            <TextBlock Text="{Binding Text}"
                                                                       FontSize="14"
                                                                       LineHeight="21"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,2,0,0"/>
                                                            <TextBlock Text="{Binding MetaText}"
                                                                       FontSize="12"
                                                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                                                       TextWrapping="Wrap"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                        <StackPanel x:Name="DetailCommentsLoadingIndicator"
                                                    Orientation="Horizontal"
                                                    HorizontalAlignment="Center"
                                                    Margin="0,12"
                                                    Visibility="Collapsed">
                                            <ProgressBar x:Name="DetailCommentsLoadingBar"
                                                          Width="28"
                                                          Height="4"
                                                          IsIndeterminate="True"/>
                                            <TextBlock Text="正在加载更多评论"
                                                       Margin="8,4,0,0"
                                                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                                <Border x:Name="DetailBottomBar"
                                        Grid.Row="1"
                                        Height="56"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Bottom"
                                        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                        BorderBrush="#22000000"
                                        BorderThickness="0,1,0,0"
                                        Visibility="Collapsed"
                                        Canvas.ZIndex="5">
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                        <Button Width="72"
                                                Margin="4,0,0,0"
                                                Background="Transparent"
                                                Click="DetailCommentButton_Click">
                                            <Grid>
                                                <FontIcon x:Name="DetailCommentFluentIcon" Glyph="&#xE8BD;" FontFamily="Segoe Fluent Icons" FontSize="18"/>
                                                <FontIcon x:Name="DetailCommentMdl2Icon" Glyph="&#xE90A;" FontFamily="Segoe MDL2 Assets" FontSize="18" Visibility="Collapsed"/>
                                            </Grid>
                                        </Button>
                                        <Button Width="72"
                                                Margin="4,0,0,0"
                                                Background="Transparent"
                                                Click="DetailLikeButton_Click">
                                            <Grid>
                                                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" Glyph="&#xEB51;" FontSize="20"/>
                                            </Grid>
