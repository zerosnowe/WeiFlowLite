<!--
    运行时指令 - .NET Native 编译优化行为配置
    对齐 Windows-Universal-Store 的兼容性策略：确保 ARM 设备上 .NET Native 不因反射裁剪而闪退
-->
<Directives xmlns="http://schemas.microsoft.com/netfx/2013/01/metadata">
  <Application>
    <!-- 应用程序自身程序集：保留所有元数据 -->
    <Assembly Name="*Application*" Dynamic="Required All" />

    <!-- Newtonsoft.Json：重度依赖反射，必须保留全部元数据 -->
    <Assembly Name="Newtonsoft.Json" Dynamic="Required All" />

    <!-- 数据模型命名空间：JSON 序列化/反序列化需要 -->
    <Namespace Name="WeiFlowLite.Models" Serialize="All" Dynamic="Required All" />

    <!-- 服务层：API 调用、认证存储等 -->
    <Namespace Name="WeiFlowLite.Services" Dynamic="Required All" />

    <!-- 常用集合类型：Newtonsoft.Json 序列化 List<T> 等需要 -->
    <Type Name="System.Collections.Generic.List" Dynamic="Required All" />
    <Type Name="System.Collections.ObjectModel.ObservableCollection" Dynamic="Required All" />
    <Type Name="System.Collections.Generic.Dictionary" Dynamic="Required All" />

    <!-- System.Linq 反射 -->
    <Namespace Name="System.Linq" Dynamic="Required All" />

    <!-- HttpClient / WebRequest 反射 -->
    <Namespace Name="System.Net.Http" Dynamic="Required All" />
  </Application>
</Directives>