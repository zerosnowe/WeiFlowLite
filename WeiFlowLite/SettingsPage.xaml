<Page
    x:Class="WeiFlowLite.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Unloaded="SettingsPage_Unloaded"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="SettingsHeader"
                Grid.Row="0"
                Padding="20,16"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="SettingsBackButton"
                        Grid.Column="0"
                        Width="48"
                        Height="48"
                        Padding="0"
                        Background="Transparent"
                        Visibility="Collapsed"
                        Click="SettingsBackButton_Click">
                    <FontIcon Glyph="&#xE72B;"/>
                </Button>
                <TextBlock Grid.Column="1"
                           Text="设置"
                           FontSize="24"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="20,0,20,20">

                <!-- 主题设置 -->
                <Border Padding="16"
                        Margin="0,0,0,8"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="主题"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <RadioButton x:Name="SystemThemeRadio"
                                     GroupName="ThemeGroup"
                                     Content="跟随系统"
                                     Checked="ThemeRadio_Checked"
                                     Tag="0"
                                     Margin="0,0,0,4"/>
                        <RadioButton x:Name="LightThemeRadio"
                                     GroupName="ThemeGroup"
                                     Content="浅色"
                                     Checked="ThemeRadio_Checked"
                                     Tag="1"
                                     Margin="0,0,0,4"/>
                        <RadioButton x:Name="DarkThemeRadio"
                                     GroupName="ThemeGroup"
                                     Content="深色"
                                     Checked="ThemeRadio_Checked"
                                     Tag="2"/>
                    </StackPanel>
                </Border>

                <!-- 磁贴设置 -->
                <Border Padding="16"
                        Margin="0,0,0,8"
                        BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="磁贴内容"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,12"/>

                        <RadioButton x:Name="RecommendedTileRadio"
                                     GroupName="LiveTileFeedGroup"
                                     Content="推荐"
                                     Checked="TileFeedRadio_Checked"
                                     Tag="0"
                                     Margin="0,0,0,4"/>
                        <RadioButton x:Name="FollowingTileRadio"
                                     GroupName="LiveTileFeedGroup"
                                     Content="关注"
                                     Checked="TileFeedRadio_Checked"
                                     Tag="1"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
